# Maton credentials for RedClaw/OpenClaw email triage.
#
# Copy this file locally to a private env file, for example:
#   ~/.openclaw/secrets/maton.env
#
# Never commit the real file. Never paste keys into workspace markdown.

MATON_TALKFIGHTCITI_EMAIL=talkfightciti@gmail.com
MATON_TALKFIGHTCITI_API_KEY=replace_with_local_secret

MATON_VIBEZBIZZ_EMAIL=vibezbizz@gmail.com
MATON_VIBEZBIZZ_API_KEY=replace_with_local_secret

# Optional, depending on the Maton skill/API integration:
MATON_BASE_URL=https://maton.ai
MATON_TRIAGE_MODE=both-inboxes
MATON_TRIAGE_STATE_PATH=~/.openclaw/state/maton-email-state.json
MATON_TRIAGE_OUTPUT_PATH=~/.openclaw/state/maton-email-latest.json
MATON_TRIAGE_COOLDOWN_SECONDS=7200
