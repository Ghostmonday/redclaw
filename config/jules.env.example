# Jules credentials and defaults.
#
# Copy locally to:
#   ~/.openclaw/secrets/jules.env
#
# Never commit the real file.
#
# Live validation on Amir's machine confirmed the authenticated Jules CLI bridge works:
#   python3 scripts/jules_session.py login
#   python3 scripts/jules_session.py sources
#   python3 scripts/jules_session.py sessions
#
# API-key auth failed with ACCESS_TOKEN_TYPE_UNSUPPORTED / API_KEY_SERVICE_BLOCKED.
# Do not use API keys for Jules unless future official docs prove otherwise.

# Primary mode: local Jules CLI handles OAuth/session auth transparently.
JULES_INTEGRATION_MODE=cli
JULES_CLI=jules

# Optional fallback mode only if direct API auth is deliberately configured.
# JULES_INTEGRATION_MODE=api
# JULES_AUTH_MODE=oauth
# JULES_OAUTH_ACCESS_TOKEN=replace_with_local_oauth_access_token
# JULES_AUTH_COOKIE=replace_with_local_cookie_if_required

JULES_BASE_URL=https://jules.googleapis.com
JULES_DEFAULT_REQUIRE_PLAN_APPROVAL=true
JULES_DEFAULT_BRANCH=main
JULES_STATE_PATH=~/.openclaw/state/jules-sessions.json
