# Jules credentials and defaults.
#
# Copy locally to:
#   ~/.openclaw/secrets/jules.env
#
# Never commit the real file.
#
# Live finding: Jules rejected API-key auth with
# ACCESS_TOKEN_TYPE_UNSUPPORTED / API_KEY_SERVICE_BLOCKED.
# Use OAuth/browser-login credentials instead.

# Preferred: OAuth2 bearer access token from `jules login` or another approved local auth flow.
JULES_OAUTH_ACCESS_TOKEN=replace_with_local_oauth_access_token

# Optional fallback if the live Jules integration requires browser-cookie auth.
# Keep this local only. Cookies are secrets.
JULES_AUTH_COOKIE=replace_with_local_cookie_if_required

# Deprecated/blocked for the observed Jules API path. Keep unset unless future docs prove otherwise.
# JULES_API_KEY=replace_with_local_secret

JULES_AUTH_MODE=oauth
JULES_BASE_URL=https://jules.googleapis.com
JULES_DEFAULT_REQUIRE_PLAN_APPROVAL=true
JULES_DEFAULT_BRANCH=main
JULES_STATE_PATH=~/.openclaw/state/jules-sessions.json
